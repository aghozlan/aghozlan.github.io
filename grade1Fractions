<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Grade 1 Math: Fun with Fractions</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Comic+Neue:wght@400;700&display=swap');
        
        body {
            font-family: 'Comic Neue', cursive;
            background-color: #f0f9ff;
            color: #333;
            /* Ensures colors print correctly */
            -webkit-print-color-adjust: exact !important;
            print-color-adjust: exact !important;
            color-adjust: exact !important;
        }

        .worksheet-container {
            max-width: 850px;
            margin: 20px auto;
            background: white;
            padding: 40px;
            border-radius: 15px;
            box-shadow: 0 10px 25px rgba(0,0,0,0.1);
            border: 4px solid #bae6fd;
        }

        .header {
            text-align: center;
            border-bottom: 3px dashed #0ea5e9;
            margin-bottom: 30px;
            padding-bottom: 20px;
        }

        .section {
            margin-bottom: 30px;
            padding: 20px;
            background: #f8fafc;
            border-radius: 10px;
            border-left: 5px solid #0ea5e9;
        }

        .section-title {
            font-size: 1.25rem;
            font-weight: bold;
            color: #0369a1;
            margin-bottom: 10px;
            display: flex;
            align-items: center;
            gap: 10px;
        }

        .shape-grid {
            display: grid;
            grid-template-columns: repeat(auto-fill, minmax(80px, 1fr));
            gap: 15px;
            margin-top: 10px;
        }

        .shape-box {
            aspect-ratio: 1;
            display: flex;
            align-items: center;
            justify-content: center;
            border: 2px solid #cbd5e1;
            border-radius: 8px;
            background: white;
            cursor: pointer;
            transition: all 0.2s;
            position: relative;
        }

        .shape-box:hover {
            border-color: #0ea5e9;
            transform: scale(1.05);
        }

        .shape-svg {
            width: 60px;
            height: 60px;
        }

        .mcq-option {
            padding: 5px 15px;
            border: 2px solid #e2e8f0;
            border-radius: 20px;
            font-size: 0.9rem;
            display: inline-block;
            margin: 5px;
        }

        /* PRINT BUTTON & UI */
        .print-controls {
            position: fixed;
            bottom: 20px;
            right: 20px;
            display: flex;
            flex-direction: column;
            align-items: flex-end;
            gap: 10px;
            z-index: 1000;
        }

        .print-btn {
            background: #0ea5e9;
            color: white;
            padding: 14px 28px;
            border-radius: 50px;
            font-weight: bold;
            box-shadow: 0 4px 15px rgba(14, 165, 233, 0.4);
            cursor: pointer;
            border: none;
            font-size: 1.1rem;
            transition: all 0.2s;
        }

        .print-btn:hover {
            background: #0284c7;
            transform: translateY(-2px);
        }

        .print-hint {
            background: rgba(0,0,0,0.7);
            color: white;
            padding: 5px 12px;
            border-radius: 4px;
            font-size: 0.8rem;
        }

        @media print {
            @page {
                size: A4;
                margin: 15mm;
            }
            .print-controls { display: none !important; }
            body { 
                background: white !important; 
                padding: 0 !important;
                margin: 0 !important;
            }
            .worksheet-container { 
                box-shadow: none !important; 
                border: none !important; 
                margin: 0 !important; 
                padding: 0 !important; 
                width: 100% !important;
                max-width: none !important;
            }
            .section { 
                break-inside: avoid; 
                background: white !important;
                border: 1px solid #e2e8f0 !important;
                margin-bottom: 20px !important;
            }
            .shape-box {
                border: 1px solid #cbd5e1 !important;
            }
            .selected-ring {
                outline: 3px solid #0ea5e9 !important;
                background-color: #f0f9ff !important;
            }
            .colored {
                fill: #38bdf8 !important;
                stroke: #0369a1 !important;
            }
        }

        /* Interaction States */
        .selected-ring {
            box-shadow: 0 0 0 4px #0ea5e9 !important;
            border-color: #0ea5e9 !important;
        }

        .colorable:hover { fill: #f0f9ff; }
        .colored { fill: #38bdf8 !important; }
    </style>
</head>
<body>

    <div class="print-controls">
        <span class="print-hint">Trouble printing? Press <b>Ctrl + P</b></span>
        <button class="print-btn" onclick="triggerPrint()">🖨️ Print Final Worksheet</button>
    </div>

    <div class="worksheet-container">
        <div class="header">
            <h1 class="text-4xl font-bold text-sky-600 mb-2">My Fraction Fun! 🍕</h1>
            <div class="flex justify-between text-lg mt-4 px-4">
                <span>Name: ______________________</span>
                <span>Date: ________________</span>
            </div>
        </div>

        <div class="section">
            <div class="section-title">1. Circle the shapes split into TWO EQUAL parts (Halves).</div>
            <p class="text-sm text-slate-500 mb-2">Check carefully! Some parts are not fair.</p>
            <div class="shape-grid" id="section1"></div>
        </div>

        <div class="section">
            <div class="section-title">2. Is the shape split into 2 Halves or 4 Quarters?</div>
            <div class="grid grid-cols-2 gap-4" id="section2"></div>
        </div>

        <div class="section">
            <div class="section-title">3. Circle the shapes split into QUARTERS only (4 equal parts).</div>
            <div class="shape-grid" id="section3"></div>
        </div>

        <div class="section">
            <div class="section-title">4. Circle the shapes split into THIRDS (3 equal parts).</div>
            <div class="shape-grid" id="section4"></div>
        </div>

        <div class="section">
            <div class="section-title">5. What fraction of the shape is SHADED?</div>
            <div class="grid grid-cols-2 gap-6" id="section5"></div>
        </div>

        <div class="section">
            <div class="section-title">6. Color ONE part, then write the fraction.</div>
            <div class="grid grid-cols-2 gap-8" id="section6"></div>
        </div>

        <div class="section">
            <div class="section-title">7. Color the items to match the fraction!</div>
            <div class="grid grid-cols-1 gap-6" id="section7"></div>
        </div>

        <div class="text-center mt-10 border-t pt-6">
            <p class="text-sky-600 font-bold text-xl italic">"Math is a superpower! Well done!"</p>
        </div>
    </div>

    <script>
        function triggerPrint() {
            window.focus();
            setTimeout(() => {
                try {
                    window.print();
                } catch (e) {
                    alert("Printing failed. Please press Ctrl+P (or Cmd+P on Mac) to print directly from your browser.");
                }
            }, 200);
        }

        const SVGS = {
            circle: (divisions = 1, unequal = false) => {
                let paths = `<circle cx="30" cy="30" r="25" stroke="black" stroke-width="2" fill="none" />`;
                if (divisions === 2) {
                    paths += unequal ? `<line x1="15" y1="8" x2="15" y2="52" stroke="black" stroke-width="2"/>` : `<line x1="30" y1="5" x2="30" y2="55" stroke="black" stroke-width="2"/>`;
                } else if (divisions === 4) {
                    paths += `<line x1="30" y1="5" x2="30" y2="55" stroke="black" stroke-width="2"/><line x1="5" y1="30" x2="55" y2="30" stroke="black" stroke-width="2"/>`;
                } else if (divisions === 3) {
                    paths += `<line x1="30" y1="30" x2="30" y2="5" stroke="black" stroke-width="2"/><line x1="30" y1="30" x2="51" y2="42" stroke="black" stroke-width="2"/><line x1="30" y1="30" x2="9" y2="42" stroke="black" stroke-width="2"/>`;
                }
                return `<svg class="shape-svg" viewBox="0 0 60 60">${paths}</svg>`;
            },
            square: (divisions = 1, unequal = false) => {
                let content = `<rect x="5" y="5" width="50" height="50" stroke="black" stroke-width="2" fill="none" />`;
                if (divisions === 2) {
                    content += unequal ? `<line x1="15" y1="5" x2="15" y2="55" stroke="black" stroke-width="2"/>` : `<line x1="30" y1="5" x2="30" y2="55" stroke="black" stroke-width="2"/>`;
                } else if (divisions === 4) {
                    content += `<line x1="30" y1="5" x2="30" y2="55" stroke="black" stroke-width="2"/><line x1="5" y1="30" x2="55" y2="30" stroke="black" stroke-width="2"/>`;
                } else if (divisions === 3) {
                    content += `<line x1="21" y1="5" x2="21" y2="55" stroke="black" stroke-width="2"/><line x1="39" y1="5" x2="39" y2="55" stroke="black" stroke-width="2"/>`;
                }
                return `<svg class="shape-svg" viewBox="0 0 60 60">${content}</svg>`;
            },
            triangle: (divisions = 2, unequal = false) => {
                let content = `<path d="M 30 5 L 55 55 L 5 55 Z" stroke="black" stroke-width="2" fill="none" />`;
                if (divisions === 2) {
                    content += unequal ? `<line x1="20" y1="20" x2="45" y2="55" stroke="black" stroke-width="2"/>` : `<line x1="30" y1="5" x2="30" y2="55" stroke="black" stroke-width="2"/>`;
                }
                return `<svg class="shape-svg" viewBox="0 0 60 60">${content}</svg>`;
            }
        };

        const toggleCircle = (el) => el.classList.toggle('selected-ring');

        // Build Section 1 (15 shapes)
        const s1 = document.getElementById('section1');
        for(let i=0; i<15; i++) {
            const unequal = i % 2 === 0;
            const type = i % 3;
            let shape = "";
            if (type === 0) shape = SVGS.square(2, unequal);
            else if (type === 1) shape = SVGS.circle(2, unequal);
            else shape = SVGS.triangle(2, unequal);
            s1.innerHTML += `<div class="shape-box" onclick="toggleCircle(this)">${shape}</div>`;
        }

        // Section 2
        const s2 = document.getElementById('section2');
        [{s:SVGS.circle(2)}, {s:SVGS.square(4)}, {s:SVGS.square(2)}, {s:SVGS.circle(4)}].forEach(i => {
            s2.innerHTML += `<div class="flex items-center gap-3 border p-2 rounded bg-white">
                <div class="shape-box">${i.s}</div>
                <div class="flex flex-col text-sm"><label><input type="radio" name="r${Math.random()}"> Half</label><label><input type="radio" name="r${Math.random()}"> Quarter</label></div>
            </div>`;
        });

        // Section 3 & 4
        [4,2,4,3,4,2,4,4].forEach(d => document.getElementById('section3').innerHTML += `<div class="shape-box" onclick="toggleCircle(this)">${SVGS.circle(d)}</div>`);
        [3,2,4,3,2,3].forEach(d => document.getElementById('section4').innerHTML += `<div class="shape-box" onclick="toggleCircle(this)">${SVGS.square(d)}</div>`);

        // Section 5
        const s5 = document.getElementById('section5');
        const s5Data = [
            { svg: `<svg class="shape-svg" viewBox="0 0 60 60"><circle cx="30" cy="30" r="25" fill="#f0f9ff" stroke="black" stroke-width="2" /><path d="M 30 5 A 25 25 0 0 1 55 30 L 30 30 Z" fill="#38bdf8" stroke="black" stroke-width="2"/></svg>`, opts: ['1/2', '1/4', '1/3'] },
            { svg: `<svg class="shape-svg" viewBox="0 0 60 60"><rect x="5" y="5" width="50" height="50" fill="#f0f9ff" stroke="black" stroke-width="2"/><rect x="5" y="5" width="25" height="50" fill="#38bdf8" stroke="black" stroke-width="2"/></svg>`, opts: ['1/2', '1/4', '1/3'] }
        ];
        s5Data.forEach(item => {
            s5.innerHTML += `<div class="flex items-center gap-4 bg-white p-3 border rounded shadow-sm">
                ${item.svg}
                <div>${item.opts.map(o => `<span class="mcq-option cursor-pointer" onclick="this.style.background='#bae6fd'">${o}</span>`).join('')}</div>
            </div>`;
        });

        // Section 6
        document.getElementById('section6').innerHTML = `
            <div class="flex flex-col items-center p-4 border rounded bg-white shadow-sm">
                <svg viewBox="0 0 60 60" class="w-20 h-20 mb-3">
                    <rect x="5" y="5" width="25" height="25" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')" />
                    <rect x="30" y="5" width="25" height="25" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')" />
                    <rect x="5" y="30" width="25" height="25" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')" />
                    <rect x="30" y="30" width="25" height="25" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')" />
                </svg>
                <div class="text-lg">This is: <b>1 / 4</b> or <b>1 / 2</b></div>
            </div>
            <div class="flex flex-col items-center p-4 border rounded bg-white shadow-sm">
                <svg viewBox="0 0 60 60" class="w-20 h-20 mb-3">
                    <path d="M 30 5 A 25 25 0 0 0 30 55 L 30 30 Z" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')" />
                    <path d="M 30 5 A 25 25 0 0 1 30 55 L 30 30 Z" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')" />
                </svg>
                <div class="text-lg">This is: <b>1 / 2</b> or <b>1 / 4</b></div>
            </div>`;

        // Section 7
        const icons = {
            heart: `<path d="M30 52 C30 52 5 35 5 18 A 12 12 0 0 1 29 18 A 12 12 0 0 1 55 18 C 55 35 30 52 30 52" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')"/>`,
            fish: `<path d="M5 30 Q 15 10 35 30 Q 15 50 5 30 M 35 30 L 55 15 L 55 45 Z" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')"/>`,
            ball: `<circle cx="30" cy="30" r="22" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')"/><path d="M 15 15 Q 30 30 15 45 M 45 15 Q 30 30 45 45" stroke="black" fill="none"/>`,
            pen: `<rect x="25" y="5" width="10" height="40" fill="none" stroke="black" stroke-width="2" class="colorable" onclick="this.classList.toggle('colored')"/><path d="M 25 45 L 30 55 L 35 45 Z" fill="none" stroke="black" />`
        };
        const sets = [
            { icon: icons.heart, n: 2, t: "Color 1/2 (half) of the hearts" },
            { icon: icons.pen, n: 4, t: "Color 1/4 (quarter) of the pens" },
            { icon: icons.fish, n: 3, t: "Color 1/3 (third) of the fishes" },
            { icon: icons.ball, n: 4, t: "Color 1/2 of the tennis balls" }
        ];
        sets.forEach(set => {
            let svgHtml = "";
            for(let j=0; j<set.n; j++) svgHtml += `<svg viewBox="0 0 60 60" class="w-12 h-12">${set.icon}</svg>`;
            document.getElementById('section7').innerHTML += `<div class="flex items-center justify-between border-b pb-4">
                <span class="font-bold text-lg">${set.t}</span>
                <div class="flex gap-4">${svgHtml}</div>
            </div>`;
        });
    </script>
</body>
</html>
