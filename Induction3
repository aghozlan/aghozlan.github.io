<div class="exam-page">
    <div class="header">
        <h1>REPUBLIC OF LEBANON</h1>
        <h2>Ministry of Education and Higher Education</h2>
        <p>Secondary Education - Life Science (LS) Section</p>
    </div>

    <table class="info-table">
        <tr>
            <td style="width: 33%;">Subject: Physics</td>
